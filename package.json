{
  "name": "markedly",
  "version": "0.1.0",
  "description": "Minimal Markdown viewer for macOS (Electron)",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron .",
    "dev": "node scripts/dev.mjs",
    "build:main": "node scripts/build-main.mjs",
    "build:renderer": "vite build",
    "pack": "npm run build && electron-builder --mac dir",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.2.4",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.7",
    "mermaid": "^11.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "sass": "^1.85.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.markedly.app",
    "productName": "Markedly",
    "files": ["dist/**", "package.json"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown document",
        "description": "Markdown text document",
        "mimeType": "text/markdown",
        "role": "Viewer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true
    },
    "directories": {
      "output": "release"
    }
  }
}
